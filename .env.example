# StemStudio local defaults.
# Copy this file to .env only when you need to override the defaults.

STEMSTUDIO_API_HOST=127.0.0.1
STEMSTUDIO_API_PORT=8000
STEMSTUDIO_FRONTEND_ORIGIN=http://127.0.0.1:5173

STEMSTUDIO_DATA_ROOT=data
STEMSTUDIO_DATABASE_PATH=data/app.db
STEMSTUDIO_UPLOADS_DIR=data/uploads
STEMSTUDIO_OUTPUT_DIR=data/outputs
STEMSTUDIO_EXPORTS_DIR=data/exports
STEMSTUDIO_TEMP_DIR=data/tmp
STEMSTUDIO_LOGS_DIR=data/logs
STEMSTUDIO_MODEL_CACHE_DIR=data/cache/models

STEMSTUDIO_WORKER_POLL_INTERVAL_SECONDS=3

STEMSTUDIO_FFMPEG_BINARY=ffmpeg
STEMSTUDIO_FFPROBE_BINARY=ffprobe
STEMSTUDIO_SEPARATOR_BINARY=audio-separator
STEMSTUDIO_YT_DLP_BINARY=yt-dlp
